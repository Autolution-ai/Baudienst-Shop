<script>
let cartCount = 0;
let finderAnswers = { step1: null, step2: null, step3: null };
let currentStep = 1;

function switchImg(el, src) {
  document.getElementById('mainImg').src = src;
  document.querySelectorAll('.thumb').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

function changeQty(delta) {
  const input = document.getElementById('qtyInput');
  const val = Math.max(1, parseInt(input.value) + delta);
  input.value = val;
}

function addToCart(name) {
  cartCount++;
  document.getElementById('cartCount').textContent = cartCount;
  const msg = name ? `<span>${name}</span> in den Warenkorb gelegt` : `<span>PG 400</span> in den Warenkorb gelegt`;
  showToast(msg);
}

function addAllToCart() {
  cartCount += 2;
  document.getElementById('cartCount').textContent = cartCount;
  showToast('Alle empfohlenen Segmente <span>hinzugefügt</span>');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.innerHTML = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// PRODUCT FINDER LOGIC
const recommendations = {
  hart: {
    abtrag: ['ELITE-GRIND EZ X\n90,87 €', 'ELITE-GRIND EZ SHARXX\n90,87 €', 'EZ T-REX SUPER PCD\n289,88 €'],
    schleifen: ['ELITE-GRIND EZ H\n90,87 €', 'ELITE-GRIND EZ X\n90,87 €', 'VARI-GRIND EZ SL\n193,26 €'],
    polieren: ['ELITE-GRIND EZ H\n90,87 €', 'VARI-GRIND EZ SL\n193,26 €', 'ELITE-GRIND EZ M\n90,87 €'],
    renovierung: ['ELITE-GRIND EZ SHARXX\n90,87 €', 'ELITE-GRIND EZ X\n90,87 €', 'EZ T-REX DOME PCD\n207,69 €'],
  },
  weich: {
    abtrag: ['ELITE-GRIND EZ S\n139,23 €', 'EZ T-REX DOME PCD\n207,69 €', 'VARI-GRIND EZ SL\n193,26 €'],
    schleifen: ['ELITE-GRIND EZ S\n139,23 €', 'ELITE-GRIND EZ M\n90,87 €', 'ELITE-GRIND EZ H\n90,87 €'],
    polieren: ['ELITE-GRIND EZ M\n90,87 €', 'VARI-GRIND EZ SL\n193,26 €', 'ELITE-GRIND EZ S\n139,23 €'],
    renovierung: ['ELITE-GRIND EZ S\n139,23 €', 'EZ T-REX DOME PCD\n207,69 €', 'ELITE-GRIND EZ M\n90,87 €'],
  },
  mittel: {
    abtrag: ['ELITE-GRIND EZ M\n90,87 €', 'EZ T-REX DOME PCD\n207,69 €', 'ELITE-GRIND EZ H\n90,87 €'],
    schleifen: ['ELITE-GRIND EZ M\n90,87 €', 'ELITE-GRIND EZ H\n90,87 €', 'VARI-GRIND EZ SL\n193,26 €'],
    polieren: ['ELITE-GRIND EZ M\n90,87 €', 'VARI-GRIND EZ SL\n193,26 €', 'ELITE-GRIND EZ H\n90,87 €'],
    renovierung: ['ELITE-GRIND EZ M\n90,87 €', 'EZ T-REX DOME PCD\n207,69 €', 'ELITE-GRIND EZ H\n90,87 €'],
  },
  beschichtet: {
    abtrag: ['EZ T-REX DOME PCD\n207,69 €', 'EZ T-REX SUPER PCD\n289,88 €', 'EZ T-REX 0 DS PCD\n139,23 €'],
    schleifen: ['EZ T-REX DOME PCD\n207,69 €', 'ELITE-GRIND EZ M\n90,87 €', 'ELITE-GRIND EZ S\n139,23 €'],
    polieren: ['EZ T-REX DOME PCD\n207,69 €', 'VARI-GRIND T-REX CLASSIC\n166,60 €', 'VARI-GRIND EZ SL\n193,26 €'],
    renovierung: ['EZ T-REX SUPER PCD\n289,88 €', 'EZ T-REX DOME PCD\n207,69 €', 'ELITE-GRIND EZ S\n139,23 €'],
  }
};

function selectOption(step, value, el) {
  const parent = el.closest('.finder-options');
  parent.querySelectorAll('.finder-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  finderAnswers['step' + step] = value;

  setTimeout(() => {
    if (step < 3) {
      document.getElementById('step' + step).classList.remove('active');
      currentStep = step + 1;
      document.getElementById('step' + currentStep).classList.add('active');
    } else {
      showFinderResult();
    }
  }, 280);
}

function showFinderResult() {
  document.getElementById('step3').classList.remove('active');
  const result = document.getElementById('finderResult');
  result.classList.add('visible');

  const key1 = finderAnswers.step1 || 'mittel';
  const key2 = finderAnswers.step2 || 'schleifen';
  const products = recommendations[key1]?.[key2] || recommendations.mittel.schleifen;

  const html = products.map(p => {
    const parts = p.split('\n');
    return `<div class="result-product" onclick="addToCart('${parts[0]}')">
      <div class="result-product-name">${parts[0]}</div>
      <div class="result-product-price">${parts[1]}</div>
      <div class="result-product-qty">inkl. MwSt. · 3er-Set</div>
    </div>`;
  }).join('');

  document.getElementById('resultProducts').innerHTML = html;
}

function restartFinder() {
  finderAnswers = { step1: null, step2: null, step3: null };
  currentStep = 1;
  for (let i = 1; i <= 3; i++) {
    const step = document.getElementById('step' + i);
    if (step) {
      step.classList.remove('active');
      step.querySelectorAll('.finder-option').forEach(o => o.classList.remove('selected'));
    }
  }
  document.getElementById('finderResult').classList.remove('visible');
  document.getElementById('step1').classList.add('active');
}
</script>
