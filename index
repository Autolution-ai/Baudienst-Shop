<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BAUDIENST – Diamantschleifer & Schleiftechnik</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root {
  --black: #0D0D0D;
  --orange: #E85A00;
  --orange-light: #FF6B10;
  --gray-bg: #F5F5F5;
  --gray-mid: #8A8A8A;
  --gray-border: #E0E0E0;
  --white: #FFFFFF;
  --text: #1A1A1A;
  --text-light: #666666;
  --success: #1A7A3F;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'Inter', -apple-system, sans-serif;
  background: var(--white);
  color: var(--text);
  font-size: 15px;
  line-height: 1.6;
}

/* ── TOPBAR ── */
.topbar {
  background: var(--black);
  color: rgba(255,255,255,0.75);
  font-size: 12px;
  padding: 8px 0;
}
.topbar-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.topbar a { color: rgba(255,255,255,0.75); text-decoration: none; }
.topbar-items { display: flex; gap: 24px; align-items: center; }
.topbar-tag {
  background: var(--orange);
  color: white;
  padding: 2px 8px;
  border-radius: 2px;
  font-weight: 600;
  font-size: 11px;
  letter-spacing: 0.05em;
}

/* ── HEADER ── */
header {
  background: var(--white);
  border-bottom: 1px solid var(--gray-border);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 1px 8px rgba(0,0,0,0.06);
}
.header-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  height: 68px;
  display: flex;
  align-items: center;
  gap: 40px;
}
.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-mark {
  width: 36px;
  height: 36px;
  background: var(--black);
  display: flex;
  align-items: center;
  justify-content: center;
}
.logo-mark svg { width: 22px; height: 22px; }
.logo-text {
  font-size: 17px;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--black);
}
.logo-sub {
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gray-mid);
  font-weight: 500;
  display: block;
  line-height: 1;
}
nav {
  display: flex;
  gap: 4px;
  flex: 1;
}
nav a {
  text-decoration: none;
  color: var(--text);
  font-size: 13.5px;
  font-weight: 500;
  padding: 6px 14px;
  border-radius: 4px;
  transition: all 0.15s;
  white-space: nowrap;
}
nav a:hover { background: var(--gray-bg); }
nav a.active { color: var(--orange); }
.header-actions {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-left: auto;
}
.btn-phone {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--gray-bg);
  border: none;
  padding: 8px 14px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
}
.btn-phone:hover { background: var(--gray-border); }
.btn-cart {
  display: flex;
  align-items: center;
  gap: 7px;
  background: var(--orange);
  color: white;
  border: none;
  padding: 8px 16px;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  position: relative;
}
.btn-cart:hover { background: var(--orange-light); }
.cart-badge {
  position: absolute;
  top: -5px;
  right: -5px;
  background: var(--black);
  color: white;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  font-size: 10px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── BREADCRUMB ── */
.breadcrumb {
  background: var(--gray-bg);
  border-bottom: 1px solid var(--gray-border);
  padding: 10px 0;
}
.breadcrumb-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12.5px;
  color: var(--text-light);
}
.breadcrumb a { color: var(--text-light); text-decoration: none; }
.breadcrumb a:hover { color: var(--orange); }
.breadcrumb span { color: var(--gray-mid); }

/* ── MAIN LAYOUT ── */
main {
  max-width: 1280px;
  margin: 0 auto;
  padding: 40px 24px 80px;
}

/* ── PRODUCT GRID ── */
.product-grid {
  display: grid;
  grid-template-columns: 1fr 480px;
  gap: 60px;
  align-items: start;
}

/* ── IMAGE GALLERY ── */
.gallery {
  position: sticky;
  top: 90px;
}
.gallery-main {
  background: var(--gray-bg);
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 4/3;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12px;
  cursor: zoom-in;
}
.gallery-main img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  padding: 24px;
}
.gallery-thumbs {
  display: flex;
  gap: 8px;
}
.thumb {
  width: 72px;
  height: 72px;
  background: var(--gray-bg);
  border-radius: 6px;
  overflow: hidden;
  cursor: pointer;
  border: 2px solid transparent;
  transition: border-color 0.15s;
  flex-shrink: 0;
}
.thumb.active { border-color: var(--orange); }
.thumb img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }
.thumb:hover { border-color: var(--gray-border); }

/* ── PRODUCT INFO ── */
.product-info {}
.product-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: #E8F5ED;
  color: var(--success);
  font-size: 11.5px;
  font-weight: 600;
  padding: 4px 10px;
  border-radius: 20px;
  margin-bottom: 14px;
}
.product-badge::before {
  content: '';
  width: 6px;
  height: 6px;
  background: var(--success);
  border-radius: 50%;
  display: inline-block;
}
.product-brand {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 8px;
}
.product-title {
  font-size: 26px;
  font-weight: 800;
  line-height: 1.25;
  color: var(--black);
  margin-bottom: 8px;
}
.product-sku {
  font-size: 12px;
  color: var(--gray-mid);
  margin-bottom: 20px;
}
.product-sku span { color: var(--text-light); font-weight: 500; }

.divider { height: 1px; background: var(--gray-border); margin: 20px 0; }

/* PRICING */
.price-block {
  margin-bottom: 20px;
}
.price-net {
  font-size: 13px;
  color: var(--text-light);
  margin-bottom: 4px;
}
.price-net strong {
  font-size: 28px;
  font-weight: 800;
  color: var(--black);
}
.price-net em { font-style: normal; font-size: 16px; font-weight: 600; }
.price-gross {
  font-size: 13px;
  color: var(--gray-mid);
}
.price-gross strong { font-weight: 600; color: var(--text-light); }
.price-tag-b2b {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: #FFF3EC;
  border: 1px solid #FFD4B3;
  color: var(--orange);
  font-size: 12px;
  font-weight: 600;
  padding: 5px 12px;
  border-radius: 4px;
  margin-top: 10px;
}

/* DELIVERY */
.delivery-info {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  margin-bottom: 8px;
  color: var(--text-light);
}
.delivery-info svg { flex-shrink: 0; }
.delivery-info strong { color: var(--success); }

/* CTA */
.cta-group {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 24px;
}
.qty-row {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 4px;
}
.qty-label { font-size: 13px; font-weight: 600; color: var(--text-light); }
.qty-control {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--gray-border);
  border-radius: 6px;
  overflow: hidden;
}
.qty-btn {
  width: 38px;
  height: 38px;
  background: var(--gray-bg);
  border: none;
  font-size: 18px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--text);
  font-weight: 500;
  transition: background 0.1s;
}
.qty-btn:hover { background: var(--gray-border); }
.qty-input {
  width: 52px;
  text-align: center;
  border: none;
  border-left: 1.5px solid var(--gray-border);
  border-right: 1.5px solid var(--gray-border);
  font-size: 15px;
  font-weight: 700;
  padding: 8px 0;
  font-family: inherit;
  color: var(--text);
  outline: none;
}
.btn-add-cart {
  width: 100%;
  background: var(--orange);
  color: white;
  border: none;
  padding: 14px 24px;
  border-radius: 7px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 9px;
  transition: background 0.15s, transform 0.1s;
  letter-spacing: 0.02em;
}
.btn-add-cart:hover { background: var(--orange-light); }
.btn-add-cart:active { transform: scale(0.99); }
.btn-request {
  width: 100%;
  background: var(--white);
  color: var(--text);
  border: 1.5px solid var(--gray-border);
  padding: 12px 24px;
  border-radius: 7px;
  font-size: 14px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: border-color 0.15s;
}
.btn-request:hover { border-color: var(--orange); color: var(--orange); }

/* TRUST */
.trust-row {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 20px;
}
.trust-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  background: var(--gray-bg);
  border-radius: 8px;
  padding: 12px 8px;
  gap: 5px;
}
.trust-item svg { color: var(--orange); }
.trust-item span {
  font-size: 11.5px;
  font-weight: 600;
  color: var(--text);
  line-height: 1.3;
}

/* SPECS */
.specs-section { margin-top: 28px; }
.section-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--gray-mid);
  margin-bottom: 14px;
}
.specs-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--gray-border);
  border: 1px solid var(--gray-border);
  border-radius: 8px;
  overflow: hidden;
}
.spec-item {
  background: var(--white);
  padding: 11px 14px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.spec-key { font-size: 11px; color: var(--gray-mid); font-weight: 500; }
.spec-val { font-size: 13.5px; font-weight: 700; color: var(--text); }

/* ── PRODUCT FINDER WIDGET ── */
.finder-section {
  margin-top: 40px;
  padding-top: 40px;
  border-top: 1px solid var(--gray-border);
}
.finder-card {
  background: var(--black);
  border-radius: 12px;
  padding: 28px 28px 32px;
  color: white;
}
.finder-eyebrow {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 10px;
}
.finder-title {
  font-size: 20px;
  font-weight: 800;
  color: white;
  margin-bottom: 6px;
}
.finder-sub {
  font-size: 13.5px;
  color: rgba(255,255,255,0.55);
  margin-bottom: 24px;
}
.finder-step { display: none; }
.finder-step.active { display: block; }
.finder-question {
  font-size: 15px;
  font-weight: 700;
  color: white;
  margin-bottom: 14px;
}
.finder-step-indicator {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 16px;
}
.step-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  transition: background 0.2s;
}
.step-dot.done { background: var(--orange); }
.step-dot.active { background: white; }
.finder-options {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.finder-option {
  background: rgba(255,255,255,0.07);
  border: 1.5px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  padding: 12px 14px;
  cursor: pointer;
  transition: all 0.15s;
  text-align: left;
}
.finder-option:hover {
  background: rgba(255,255,255,0.12);
  border-color: rgba(255,255,255,0.3);
}
.finder-option.selected {
  background: rgba(232,90,0,0.15);
  border-color: var(--orange);
}
.option-label {
  font-size: 13.5px;
  font-weight: 700;
  color: white;
  display: block;
  margin-bottom: 2px;
}
.option-desc {
  font-size: 11.5px;
  color: rgba(255,255,255,0.5);
  display: block;
}
.finder-result {
  display: none;
}
.finder-result.visible {
  display: block;
}
.result-label {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 12px;
}
.result-products {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}
.result-product {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px;
  padding: 12px;
  cursor: pointer;
  transition: all 0.15s;
}
.result-product:hover {
  background: rgba(255,255,255,0.1);
  border-color: rgba(255,255,255,0.25);
}
.result-product-name {
  font-size: 12px;
  font-weight: 700;
  color: white;
  margin-bottom: 4px;
  line-height: 1.3;
}
.result-product-price {
  font-size: 13px;
  font-weight: 800;
  color: var(--orange);
}
.result-product-qty {
  font-size: 10.5px;
  color: rgba(255,255,255,0.4);
  margin-top: 2px;
}
.btn-finder-cart {
  width: 100%;
  background: var(--orange);
  color: white;
  border: none;
  padding: 13px;
  border-radius: 7px;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  margin-top: 4px;
}
.btn-finder-restart {
  width: 100%;
  background: transparent;
  color: rgba(255,255,255,0.5);
  border: none;
  padding: 10px;
  font-size: 12px;
  cursor: pointer;
  margin-top: 6px;
  text-align: center;
}
.btn-finder-restart:hover { color: rgba(255,255,255,0.8); }

/* ── CROSS-SELL SECTION ── */
.cross-sell {
  margin-top: 72px;
  padding-top: 48px;
  border-top: 1px solid var(--gray-border);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 28px;
}
.section-title {
  font-size: 22px;
  font-weight: 800;
  color: var(--black);
}
.section-subtitle {
  font-size: 13.5px;
  color: var(--text-light);
  margin-top: 4px;
}
.view-all {
  font-size: 13px;
  font-weight: 600;
  color: var(--orange);
  text-decoration: none;
  white-space: nowrap;
}
.products-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}
.product-card {
  border: 1.5px solid var(--gray-border);
  border-radius: 10px;
  overflow: hidden;
  transition: all 0.2s;
  cursor: pointer;
  background: white;
}
.product-card:hover {
  border-color: var(--orange);
  box-shadow: 0 4px 16px rgba(232,90,0,0.1);
  transform: translateY(-2px);
}
.card-img {
  background: var(--gray-bg);
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.card-img img { width: 80%; height: 80%; object-fit: contain; padding: 12px; }
.card-body { padding: 14px; }
.card-brand {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--orange);
  margin-bottom: 5px;
}
.card-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text);
  line-height: 1.35;
  margin-bottom: 6px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-desc {
  font-size: 11.5px;
  color: var(--text-light);
  line-height: 1.4;
  margin-bottom: 10px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 10px;
}
.card-price {
  font-size: 15px;
  font-weight: 800;
  color: var(--black);
}
.card-price small {
  font-size: 11px;
  font-weight: 400;
  color: var(--gray-mid);
  display: block;
  line-height: 1;
}
.card-qty-tag {
  font-size: 10px;
  font-weight: 600;
  background: #FFF3EC;
  color: var(--orange);
  padding: 2px 7px;
  border-radius: 3px;
}
.btn-card-cart {
  width: 34px;
  height: 34px;
  background: var(--orange);
  border: none;
  border-radius: 6px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.15s;
}
.btn-card-cart:hover { background: var(--orange-light); }
.btn-card-cart svg { color: white; }

/* ── USP BAR ── */
.usp-bar {
  background: var(--black);
  padding: 32px 0;
  margin-top: 72px;
}
.usp-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.usp-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.usp-icon {
  width: 42px;
  height: 42px;
  background: rgba(232,90,0,0.15);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.usp-icon svg { color: var(--orange); }
.usp-text {}
.usp-title {
  font-size: 14px;
  font-weight: 700;
  color: white;
  margin-bottom: 3px;
}
.usp-desc {
  font-size: 12.5px;
  color: rgba(255,255,255,0.45);
  line-height: 1.4;
}

/* ── FOOTER ── */
footer {
  background: var(--gray-bg);
  border-top: 1px solid var(--gray-border);
  padding: 40px 0 24px;
}
.footer-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1.5fr;
  gap: 40px;
  margin-bottom: 32px;
}
.footer-brand {}
.footer-brand .logo { margin-bottom: 14px; }
.footer-desc {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.6;
  max-width: 260px;
}
.footer-col h4 {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text);
  margin-bottom: 14px;
}
.footer-col ul { list-style: none; }
.footer-col li {
  margin-bottom: 8px;
}
.footer-col a {
  font-size: 13px;
  color: var(--text-light);
  text-decoration: none;
}
.footer-col a:hover { color: var(--orange); }
.footer-contact p {
  font-size: 13px;
  color: var(--text-light);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 7px;
}
.footer-contact strong { color: var(--text); }
.footer-bottom {
  max-width: 1280px;
  margin: 0 auto;
  padding: 20px 24px 0;
  border-top: 1px solid var(--gray-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 12px;
  color: var(--gray-mid);
}

/* ── WHATSAPP BUTTON ── */
.whatsapp-fab {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 52px;
  height: 52px;
